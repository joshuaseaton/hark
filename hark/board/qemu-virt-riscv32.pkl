// The specs for qemu-virt-riscv32 and qemu-virt-riscv64 are identical
// so we make qemu-virt-riscv64.pkl a symlink of qemu-virt-riscv32.pkl.

amends "spec.pkl"

local class BoardOptions {
  mMode: Boolean = true
}
local boardOpts = rawBoardOptions.toTyped(BoardOptions)

platform = "qemu-virt-riscv"

arch = new ArchRiscv {
  mMode = boardOpts.mMode
}

// Accounts for OpenSBI being loaded at the base of RAM.
local loadOffset = if (boardOpts.mMode) 0 else 0x0020_0000
loadAddress = 0x8000_0000 + loadOffset
