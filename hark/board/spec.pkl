import "pkl:json"

// Optional JSON file of kernel options.
local const optionsFile = read?("prop:options")
local const optionsMap =
  if (optionsFile == null)
    Map()
  else
    (new json.Parser {}).parse(read(optionsFile).text).toMap()

// Individual $board.pkl files can define their own local schema for
// their board options in the form of a class, and then do
// `rawBoardOptions.toTyped(MyConcreteBoardOptions)` to deserialize.
hidden const rawBoardOptions = optionsMap.getOrNull("board") ?? new Dynamic {}

class ArchRiscv {
  // Used as a deserialization tag.
  fixed name: String = "riscv"

  // The mode we are booted in: "m" for machine and "s" for supervisor.
  entryMode: "m" | "s"
}

//
// The board spec schema.
//
// Individual $board.pkl files must conform to this schema and are expected to
// amend this file in order to enforce that.
//

// The name of the targeted platform.
platform: String

// The architecture-specific spec.
arch: ArchRiscv

// The physical address at which the kernel will be loaded.
loadAddress: UInt

class Options {
  //
  // RISC-V-specific options.
  //

  // Whether to use the SBI debug console as hark's console. Only valid if
  // entering in supervisor mode.
  riscvSbiConsole: Boolean = false
}

options = optionsMap.remove("board").toTyped(Options)
