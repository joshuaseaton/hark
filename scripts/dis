# Disassembles the example hark app.
def main [
    --release  # Disassemble the release build
] {
    $env.RUST_TARGET_PATH = [ $env.FILE_PWD .. hark board ] | path join
    let release_flag = if $release { [--release] } else { [] }
    ^cargo objdump ...$release_flag -- --disassemble --demangle --line-numbers
}
