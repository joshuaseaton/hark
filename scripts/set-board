# Sets config.toml for a given board.
def main [board: string] {
    cd $env.FILE_PWD
    cd ..

    let target_json = [hark board $"($board).json"] | path join
    if not ($target_json | path exists) {
        error make --unspanned $"no target JSON defined for ($board) at ($target_json)"
    }
    let toml = {
        env: { HARK_BOARD: $board }
        build: { target: [$target_json] }
    } | to toml

    let set_board = [scripts set-board] | path join
    $"# Generated by `($set_board) ($board)`\n\n" + $toml |
        save --force ".cargo/board.toml"
}
