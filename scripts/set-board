# Sets config.toml for a given board.
def main [
    board?: string  # The board name to set (omit to list the available boards)
] {
    cd $env.FILE_PWD
    cd ..

    let board_dir = [hark board] | path join
    if ($board == null) {
        print "Available boards:"
        ls $board_dir
            | get name
            | path basename
            | where ($it | str ends-with ".json")
            | path parse
            | get stem
            | each { |board| print $"* ($board)" }
        return
    }

    let target_json = [$board_dir $"($board).json"] | path join
    if not ($target_json | path exists) {
        error make --unspanned $"no target JSON defined for ($board) at ($target_json)"
    }
    let toml = {
        env: { HARK_BOARD: $board }
        build: { target: [$target_json] }
        unstable: {json-target-spec: true }
    } | to toml

    let set_board = [scripts set-board] | path join
    $"# Generated by `($set_board) ($board)`\n\n" + $toml |
        save --force ".cargo/board.toml"
}
