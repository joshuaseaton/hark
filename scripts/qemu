# If a QEMU board is set, this will build the example Hark system and run it
# under the appropriate QEMU configuration.
def main [] {
    cd $env.FILE_PWD
    cd ..

    let board_toml = [ .cargo board.toml ] | path join
    if not ($board_toml | path exists) {
        error make --unspanned "Run `cargo set-board` first"
    }
    let board = open $board_toml | get env.HARK_BOARD
    let qemu = match $board {
        "qemu-virt-riscv32" => "qemu-system-riscv32"
        "qemu-virt-riscv64" => "qemu-system-riscv64"
        _ => { error make --unspanned $"($board) is not a QEMU board" }
    }

    # `cargo build` can give structured output for finding where the kernel is.
    #
    # Build failures are hard to parse in structured output though, so we build
    # first in a way that will surface any errors as usual. And then we can
    # (silently) rebuild and be sure that the information we want is present in
    # the JSON.
    do --capture-errors { ^cargo build }
    let system = ^cargo build --message-format=json-diagnostic-short
        | complete
        | get stdout
        | lines
        | each { from json }
        | where executable? != null
        | get 0.executable
        | path relative-to $env.PWD

    mut command = [$qemu -machine virt -nographic -kernel $system]

    # Hark's build script will have written out the evaluation of the board spec
    # to the top-level artifact directory.
    let spec = [target $board debug spec.json] | path join | open
    match ($spec | get arch.name) {
        "riscv" => {
            if ($spec | get arch.mMode) {
                $command ++= [-bios none]
            }
        }
    }

    # Set up .build-id directory for llvm-symbolizer --filter-markup.
    # TODO: Update llvm-symbolizer so that `llvm-symbolizer --obj $system` can
    # work without a .build-id directory. 
    let build_id = (^llvm-readelf -n $system
        | lines
        | find "Build ID"
        | get 0
        | ansi strip
        | split row ": "
        | last
        | str trim)
    let bid_prefix = ($build_id | str substring 0..<2)
    let bid_suffix = ($build_id | str substring 2..)
    let bid_dir = [ target .build-id $bid_prefix ] | path join
    mkdir $bid_dir
    ^ln -sf ($system | path expand) ([$bid_dir $"($bid_suffix).debug"] | path join)

    run-external $command.0 ...($command | skip 1)
        | (
            ^llvm-symbolizer
            --filter-markup
            --relativenames
            --color=never
            --debug-file-directory target/
        )
}
